# Greater — environment variables
#
# Copy this file to `.env` and fill in the values that apply to you.
# Nothing here is required for the Bitcoin demo to *render* — the
# browser-local LLM and the catalog navigator both work with no keys.
# These keys exist for the optional cloud-fallback path, the contact
# form, and the database that backs admin tooling.
#
# Never commit .env. It's already in .gitignore.

# ---------------------------------------------------------------------
# DATABASE_URL — PostgreSQL connection string.
# Used by: the admin feedback inbox, the help-articles seed, and the
# Express API server. The Bitcoin chat demo does not use the database.
# Get a free instance from Neon, Supabase, or Replit's built-in Postgres.
# Format: postgresql://user:password@host:port/dbname
# ---------------------------------------------------------------------
DATABASE_URL=

# ---------------------------------------------------------------------
# TOGETHER_API_KEY — Together.AI API key.
# Used by: the cloud-fallback answer-polishing path. The Bitcoin demo
# only fires this *after* the in-browser navigator has already picked a
# leaf — never on retrieval. Estimated cost at launch traffic: dollars,
# not hundreds of dollars. Optional: omit it and the bot will reply
# from the catalog brief verbatim.
# Get a key at: https://api.together.xyz/settings/api-keys
# ---------------------------------------------------------------------
TOGETHER_API_KEY=

# ---------------------------------------------------------------------
# VITE_WEB3FORMS_ACCESS_KEY — Web3Forms key for the public Contact form.
# Used by: the /contact page submission. Web3Forms is a free relay that
# emails form submissions to your inbox without needing your own backend.
# Get a key at: https://web3forms.com/  (free tier is plenty for launch)
# Without it, the contact form will render but submissions will fail.
# ---------------------------------------------------------------------
VITE_WEB3FORMS_ACCESS_KEY=

# ---------------------------------------------------------------------
# ADMIN_FEEDBACK_KEY — bearer token for the admin feedback inbox.
# Used by: the /admin/feedback page (protected by a simple bearer check
# in the API server). Generate a long random string; only you need to
# know it. If you don't plan to use the admin UI, leave it empty.
# ---------------------------------------------------------------------
ADMIN_FEEDBACK_KEY=

# ---------------------------------------------------------------------
# GITHUB_TOKEN — GitHub personal access token (read-only is enough).
# Used by: `pnpm --filter @workspace/scripts run build-bitcoin-seed`
# when it pulls Bitcoin Core / Knots commit metadata for the corpus.
# Without it, the public anonymous rate limit (60 req/hr) makes a full
# rebuild fail partway through. Not needed at runtime — only for the
# corpus build.
# Create at: https://github.com/settings/tokens (no scopes required)
# ---------------------------------------------------------------------
GITHUB_TOKEN=
